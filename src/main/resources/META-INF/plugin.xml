<idea-plugin>
    <id>io.infracost.plugins.jetbrains-infracost</id>
    <name>Infracost</name>
    <vendor email="hello@infracost.io" url="https://infracost.io">Infracost</vendor>

    <description><![CDATA[
    Cloud cost estimates for Terraform right in your editor.
    Powered by <a href="https://www.infracost.io">Infracost</a>.
    <br/><br/>
    Bundles <code>infracost-ls</code>. You can also override the binary path in Settings.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.ultimate</depends>

    <applicationListeners>
        <listener class="com.infracost.intellij.InfracostSaveListener"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="Infracost" displayType="BALLOON"/>
        <platform.lsp.serverSupportProvider
                implementation="com.infracost.intellij.InfracostLspServerSupportProvider"/>
        <codeInsight.codeVisionProvider
                implementation="com.infracost.intellij.InfracostCodeVisionProvider"/>
        <applicationConfigurable parentId="tools"
                                 instance="com.infracost.intellij.InfracostSettingsConfigurable"
                                 id="com.infracost.intellij.InfracostSettingsConfigurable"
                                 displayName="Infracost"/>
        <applicationService serviceImplementation="com.infracost.intellij.InfracostSettingsState"/>
        <toolWindow id="Infracost" secondary="true" anchor="right" icon="/icons/toolWindow.svg"
                    factoryClass="com.infracost.intellij.InfracostToolWindowFactory"/>
        <statusBarWidgetFactory implementation="com.infracost.intellij.InfracostStatusBarWidgetFactory"
                                id="InfracostStatusBar"/>
    </extensions>
</idea-plugin>
